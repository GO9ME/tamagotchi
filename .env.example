# --- LifeGotchi 환경변수 예시 ---
# 복사해서 .env.local 로 저장하세요.

# 게임 1년 = 현실 몇 ms (기본 540000 = 9분 → 정년 60세까지 약 9시간 한 판)
# 빠른 테스트는 작게(예: 5000), 느린 플레이는 크게.
NEXT_PUBLIC_GAME_YEAR_MS=540000

# --- 아래는 Phase 3+ 에서 Supabase 익명 인증을 붙일 때 사용 (지금은 불필요) ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
