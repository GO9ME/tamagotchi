# --- LifeGotchi 환경변수 예시 ---
# 복사해서 .env.local 로 저장하세요.

# 게임 시간 배율: 게임 1년이 현실 몇 밀리초인지 (기본 86400000 = 현실 1일 = 게임 1년)
# 개발/테스트 중 빠르게 나이 변화를 보고 싶으면 작은 값으로 바꾸세요. (예: 600000 = 10분)
NEXT_PUBLIC_GAME_YEAR_MS=86400000

# --- 아래는 Phase 3+ 에서 Supabase 익명 인증을 붙일 때 사용 (지금은 불필요) ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
